{
  "expo": {
    "name": "style-assistant",
    "slug": "style-assistant",
    "version": "1.0.0",
    "platforms": [
      "ios"
    ],
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "styleassistant",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.krispyk84.styleassistant",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Style Assistant uses your photo library so you can upload anchor items, candidate pieces, and outfit selfies.",
          "cameraPermission": "Style Assistant uses the camera so you can capture anchor items, candidate pieces, and outfit selfies."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FCFAF7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
