generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OutfitTier {
  BUSINESS
  SMART_CASUAL
  CASUAL
}

enum AnalysisVerdict {
  WORKS_GREAT
  WORKS_OKAY
  DOESNT_WORK
}

enum UploadedImageCategory {
  ANCHOR_ITEM
  CANDIDATE_PIECE
  SELFIE
}

model UserProfile {
  id                   String               @id @default(cuid())
  supabaseUserId       String?
  name                 String               @default("")
  gender               String
  heightCm             Float
  weightKg             Float
  fitPreference        String
  stylePreference      String
  budget               String
  hairColor            String
  skinTone             String
  summerBottomPreference String           @default("prefer-trousers")
  temperatureUnit      String              @default("celsius")
  bodyType             String?
  weightDistribution   String?
  fitTendency          String?
  notes                String?
  onboardingCompleted  Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  outfitRequests       OutfitRequest[]
  compatibilityChecks  CompatibilityCheck[]
  selfieReviews        SelfieReview[]

  @@index([supabaseUserId])
}

model OutfitRequest {
  id                    String         @id
  profileId             String?
  supabaseUserId        String?
  anchorImageId         String?
  anchorItemDescription String
  anchorImageUrl        String?
  photoPending          Boolean        @default(false)
  selectedTiers         OutfitTier[]
  weatherContext        Json?
  promptVersion         String         @default("mock-v1")
  status                String         @default("completed")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  profile               UserProfile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  anchorImage           UploadedImage? @relation("AnchorItemImage", fields: [anchorImageId], references: [id], onDelete: SetNull)
  result                OutfitResult?

  @@index([supabaseUserId])
}

model OutfitResult {
  id             String       @id @default(cuid())
  requestId      String       @unique
  status         String
  provider       String       @default("mock")
  rawResponse    Json?
  generatedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  request        OutfitRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tierResults    TierResult[]
}

model TierResult {
  id                String      @id @default(cuid())
  outfitResultId    String
  tier              OutfitTier
  title             String
  anchorItem        String
  keyPieces         Json
  shoes             Json
  accessories       Json
  fitNotes          Json
  whyItWorks        String
  stylingDirection  String
  detailNotes       Json
  sketchStatus      String      @default("pending")
  sketchImageUrl    String?
  sketchStorageKey  String?
  sketchMimeType    String?
  sketchImageData   Bytes?
  variantIndex      Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  outfitResult      OutfitResult @relation(fields: [outfitResultId], references: [id], onDelete: Cascade)

  @@unique([outfitResultId, tier])
}

model CompatibilityCheck {
  id                String           @id @default(cuid())
  profileId         String?
  imageId           String?
  imageUrl          String?
  imageKey          String?
  imageFilename     String?
  imageMimeType     String?
  imageWidth        Int?
  imageHeight       Int?
  imageSizeBytes    Int?
  verdict           AnalysisVerdict
  stylistNotes      Json
  suggestedChanges  Json
  rawResponse       Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  profile           UserProfile?     @relation(fields: [profileId], references: [id], onDelete: SetNull)
  image             UploadedImage?   @relation("CompatibilityImage", fields: [imageId], references: [id], onDelete: SetNull)
}

model SelfieReview {
  id                String           @id @default(cuid())
  profileId         String?
  imageId           String?
  imageUrl          String?
  imageKey          String?
  imageFilename     String?
  imageMimeType     String?
  imageWidth        Int?
  imageHeight       Int?
  imageSizeBytes    Int?
  verdict           AnalysisVerdict
  stylistNotes      Json
  suggestedChanges  Json
  rawResponse       Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  profile           UserProfile?     @relation(fields: [profileId], references: [id], onDelete: SetNull)
  image             UploadedImage?   @relation("SelfieImage", fields: [imageId], references: [id], onDelete: SetNull)
}

model UploadedImage {
  id                    String                 @id @default(cuid())
  category              UploadedImageCategory
  storageProvider       String
  storageKey            String                 @unique
  publicUrl             String
  originalFilename      String?
  mimeType              String?
  sizeBytes             Int?
  width                 Int?
  height                Int?
  imageData             Bytes?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  anchorItemRequests    OutfitRequest[]        @relation("AnchorItemImage")
  compatibilityChecks   CompatibilityCheck[]   @relation("CompatibilityImage")
  selfieReviews         SelfieReview[]         @relation("SelfieImage")
}

model ClosetItem {
  id               String   @id @default(cuid())
  supabaseUserId   String?
  title            String
  brand            String   @default("")
  size             String   @default("")
  category         String   @default("Clothing")
  uploadedImageUrl String?
  sketchImageUrl   String?
  sketchStorageKey String?
  sketchMimeType   String?
  sketchImageData  Bytes?
  sketchStatus     String   @default("failed")
  savedAt          DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ── Design metadata ──────────────────────────────────────────────────────
  subcategory      String?
  primaryColor     String?
  colorFamily      String?
  material         String?
  formality        String?
  silhouette       String?
  season           String?
  weight           String?
  pattern          String?
  notes            String?

  // ── Personal fit ─────────────────────────────────────────────────────────
  fitStatus        String?

  // ── Sunglasses-specific ───────────────────────────────────────────────────
  lensShape        String?
  frameColor       String?

  // ── Usage counters ────────────────────────────────────────────────────────
  timesAnchored    Int       @default(0)
  lastAnchoredAt   DateTime?
  matchCount       Int       @default(0)

  @@index([supabaseUserId])
}

model ClosetSketchJob {
  id               String   @id @default(cuid())
  status           String   @default("pending")
  sketchImageUrl   String?
  sketchStorageKey String?
  sketchMimeType   String?
  sketchImageData  Bytes?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AiUsageEntry {
  id             String   @id @default(cuid())
  supabaseUserId String
  monthKey       String
  feature        String
  model          String
  costUsd        Float
  inputTokens    Int?
  outputTokens   Int?
  createdAt      DateTime @default(now())

  @@index([supabaseUserId, monthKey])
}

model SavedTrip {
  id             String   @id @default(cuid())
  supabaseUserId String
  tripId         String   // client-generated, used for upsert dedup
  destination    String
  country        String
  departureDate  String   // YYYY-MM-DD
  returnDate     String   // YYYY-MM-DD
  travelParty    String
  climateLabel   String
  styleVibe      String
  purposes       Json     // string[]
  activities     String?
  dressCode      String?
  days           Json     // TripOutfitDay[] — full client state including sketches
  savedAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([supabaseUserId, tripId])
  @@index([supabaseUserId])
}

// ── Trip Planning ─────────────────────────────────────────────────────────────

model TripPlan {
  id             String       @id @default(cuid())
  supabaseUserId String
  // Destination
  destination    String
  country        String
  // Dates
  departureDate  String                    // YYYY-MM-DD
  returnDate     String                    // YYYY-MM-DD
  numDays        Int
  // Trip details
  travelParty    String
  purposes       Json                      // string[]
  // Climate
  climateLabel   String
  styleVibe      String
  // Smart packing
  willSwim       Boolean      @default(false)
  fancyNights    Boolean      @default(false)
  workoutClothes Boolean      @default(false)
  laundryAccess  String       @default("Unsure")
  shoesCount     String       @default("2")
  carryOnOnly    Boolean      @default(false)
  activities     String?
  dressCode      String?
  specialNeeds   String?
  // Anchor selection
  anchorMode     String?                   // guided | auto | manual
  // Lifecycle
  status         String       @default("draft")  // draft | generating | generated
  tripId         String?                   // set after generation
  anchors        TripAnchor[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([supabaseUserId])
}

model TripAnchor {
  id              String    @id @default(cuid())
  tripPlanId      String
  tripPlan        TripPlan  @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  supabaseUserId  String
  slotId          String?                // guided-mode slot reference
  label           String
  category        String
  source          String                 // closet | camera | library | ai_suggested
  closetItemId    String?
  uploadedImageId String?
  imageUrl        String?
  rationale       String?
  position        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tripPlanId])
  @@index([supabaseUserId])
}

model StyleGuideDocument {
  id                  String   @id @default(cuid())
  name                String
  sourceFilename      String
  sourceMimeType      String?
  sourcePath          String?
  processedTextPath   String?
  openAiFileId        String?
  vectorStoreId       String
  retrievalProvider   String   @default("openai")
  status              String   @default("ready")
  active              Boolean  @default(true)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
